# =========================
# 数据接口密钥（按需填写）
# =========================
# Tushare Token（推荐配置；为空时会自动降级到公开源）
TUSHARE_TOKEN=your_tushare_token_here

# =========================
# 网络与抓取参数（可选）
# =========================
# 1=忽略SSL证书校验（校园网/代理环境可用），0=严格校验
IGNORE_SSL_VERIFY=1

# HTTP重试次数（失败后自动重试）
HTTP_RETRIES=2

# 事件抓取列表页最大页数
EVENT_MAX_PAGES=6

# =========================
# 行情抓取参数（可选）
# =========================
# Tushare回看天数（用于获取交易日历）
MARKET_LOOKBACK_DAYS=120

# 最大交易日数量（Tushare daily按交易日抓取）
MARKET_MAX_TRADE_DAYS=60

# 公开源抓取最大股票数（事件提取代码 + 种子池）
MARKET_MAX_SYMBOLS=30

# 公开源区间（Yahoo range）
MARKET_PUBLIC_RANGE=2y
